#!/usr/bin/env python
"""Initialize an instance of the Circulation Manager"""
from pathlib import Path

from palace.manager.scripts.initialization import InstanceInitializationScript

# Resolve paths relative to this script's location in the repository.
repo_root = Path(__file__).parent.parent.parent
alembic_ini = repo_root / "alembic.ini"
startup_tasks_dir = repo_root / "startup_tasks"

InstanceInitializationScript(
    config_file=alembic_ini,
    startup_tasks_dir=startup_tasks_dir,
).run()
